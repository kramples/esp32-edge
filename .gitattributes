# Normalize line endings across contributors' machines:
# text files are stored with LF in the repository, and Git converts to the
# developer's native EOL on checkout. This silences the LF/CRLF warnings on
# Windows and prevents whole-file diffs caused by EOL churn.
* text=auto

# Shell scripts must stay LF even on Windows checkouts (CRLF breaks sh).
*.sh text eol=lf
